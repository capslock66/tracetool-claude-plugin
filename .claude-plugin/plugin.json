{
  "name": "tracetool",
  "displayName": "TraceTool",
  "version": "15.0.4",
  "description": "Send structured traces to the TraceTool viewer from Claude Code. Supports debug/warning/error messages, indented scopes, object trees, XML, tables, and watches.",
  "author": {
    "name": "Thierry Parent"
  },
  "homepage": "https://github.com/capslock66/Tracetool",
  "repository": "https://github.com/capslock66/Tracetool",
  "license": "ISC",
  "keywords": ["tracetool", "tracing", "debugging", "viewer", "log"],
  "permissions": {
    "allow": [
      "mcp__plugin_tracetool_tracetool__*",
      "mcp__tracetool__*"
    ]
  },
  "mcpServers": {
    "tracetool": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/server.js"],
      "env": {
        "TRACETOOL_HOST": "127.0.0.1:81"
      }
    }
  }
}
